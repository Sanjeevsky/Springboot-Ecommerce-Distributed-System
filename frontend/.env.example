# Trove frontend environment.
# Copy to `.env.local` and adjust. Vite exposes only VITE_*-prefixed vars.

# Base path the app calls. In dev, the Vite proxy maps /api -> the gateway
# (see vite.config.js). In production, point this at your gateway/ingress.
VITE_API_BASE=/api

# Used only by the dev proxy target. Your Spring Cloud Gateway port.
VITE_GATEWAY_URL=http://localhost:8081

# When "true", the app serves built-in mock data instead of calling the API.
# Great for designing/iterating before the backend is running.
VITE_USE_MOCKS=true
