    {
      "name": "02 \u2014 Login \u2192 save token",
      "event": [
        {
          "listen": "test",
          "script": {
            "type": "text/javascript",
            "exec": [
              "pm.test('Login: status 200', () => pm.response.to.have.status(200));",
              "var json = pm.response.json();",
              "var token = json && json.data && (typeof json.data === 'string' ? json.data : json.data.token);",
              "pm.test('Token present', () => pm.expect(token).to.be.a('string').and.not.empty);",
              "pm.collectionVariables.set('token', token);",
              "try { pm.environment.set('token', token); } catch (e) {}",
              "console.log('Token saved:', token.substring(0, 30) + '...');"
            ]
          }
        }
      ],
      "request": {
        "method": "POST",
        "header": [
