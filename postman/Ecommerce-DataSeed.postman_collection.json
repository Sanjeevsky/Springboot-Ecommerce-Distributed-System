{
  "info": {
    "name": "Ecommerce — Data Seed & E2E Flow",
    "_postman_id": "ecommerce-dataseed-collection",
    "description": "Run these requests IN ORDER (use Collection Runner). Each request extracts IDs and passes them automatically to the next step. Covers the full commerce flow: register → catalog setup → inventory → cart → order → payment. Run against http://localhost:8081 with all services up.",
    "schema": "https://schema.getpostman.com/json/collection/v2.1.0/collection.json"
  },
  "variable": [
    { "key": "baseUrl",       "value": "http://localhost:8081" },
    { "key": "token",         "value": "" },
    { "key": "brandId",       "value": "" },
    { "key": "categoryId",    "value": "" },
    { "key": "subCategoryId", "value": "" },
    { "key": "productId",     "value": "" },
    { "key": "variantId",     "value": "" },
    { "key": "addressId",     "value": "" },
    { "key": "orderId",       "value": "" },
    { "key": "paymentId",     "value": "" }
  ],
  "item": [
    {
      "name": "01 — Register User",
      "event": [
        {
          "listen": "test",
          "script": {
            "exec": [
              "pm.test('Register: status 201', () => pm.response.to.have.status(201));"
            ]
          }
        }
      ],
      "request": {
        "method": "POST",
        "header": [{ "key": "Content-Type", "value": "application/json" }],
        "url": { "raw": "{{baseUrl}}/auth-service/signup", "host": ["{{baseUrl}}"], "path": ["auth-service","signup"] },
        "body": {
          "mode": "raw",
          "raw": "{\n  \"name\": \"Test Buyer\",\n  \"email\": \"buyer@example.com\",\n  \"password\": \"password123\",\n  \"role\": \"USER\"\n}"
        }
      }
    },
    {
      "name": "02 — Login → save token",
      "event": [
        {
          "listen": "test",
          "script": {
            "exec": [
              "pm.test('Login: status 200', () => pm.response.to.have.status(200));",
              "var json = pm.response.json();",
              "pm.test('Token present', () => pm.expect(json.data).to.be.a('string'));",
              "pm.collectionVariables.set('token', json.data);",
              "console.log('Token saved:', json.data.substring(0,30) + '...');"
            ]
          }
        }
      ],
      "request": {
        "method": "POST",
        "header": [{ "key": "Content-Type", "value": "application/json" }],
        "url": { "raw": "{{baseUrl}}/auth-service/login", "host": ["{{baseUrl}}"], "path": ["auth-service","login"] },
        "body": {
          "mode": "raw",
          "raw": "{\n  \"email\": \"buyer@example.com\",\n  \"password\": \"password123\"\n}"
        }
      }
    },
    {
      "name": "03 — Add Brand (Samsung)",
      "event": [
        {
          "listen": "test",
          "script": {
            "exec": [
              "pm.test('Add Brand: status 201', () => pm.response.to.have.status(201));",
              "var json = pm.response.json();",
              "pm.test('Brand ID present', () => pm.expect(json.data.id).to.be.a('string'));",
              "pm.collectionVariables.set('brandId', json.data.id);",
              "console.log('brandId:', json.data.id);"
            ]
          }
        }
      ],
      "request": {
        "method": "POST",
        "header": [{ "key": "Authorization", "value": "Bearer {{token}}" }],
        "url": {
          "raw": "{{baseUrl}}/catalog-service/add-brand?name=Samsung",
          "host": ["{{baseUrl}}"], "path": ["catalog-service","add-brand"],
          "query": [{ "key": "name", "value": "Samsung" }]
        }
      }
    },
    {
      "name": "04 — Add Category (Electronics)",
      "event": [
        {
          "listen": "test",
          "script": {
            "exec": [
              "pm.test('Add Category: status 201', () => pm.response.to.have.status(201));",
              "var json = pm.response.json();",
              "pm.test('Category ID present', () => pm.expect(json.data.id).to.be.a('string'));",
              "pm.collectionVariables.set('categoryId', json.data.id);",
              "console.log('categoryId:', json.data.id);"
            ]
          }
        }
      ],
      "request": {
        "method": "POST",
        "header": [{ "key": "Authorization", "value": "Bearer {{token}}" }],
        "url": {
          "raw": "{{baseUrl}}/catalog-service/addCategory?categoryName=Electronics",
          "host": ["{{baseUrl}}"], "path": ["catalog-service","addCategory"],
          "query": [{ "key": "categoryName", "value": "Electronics" }]
        }
      }
    },
    {
      "name": "05 — Add SubCategory (Smartphones)",
      "event": [
        {
          "listen": "test",
          "script": {
            "exec": [
              "pm.test('Add SubCategory: status 201', () => pm.response.to.have.status(201));",
              "var json = pm.response.json();",
              "pm.test('SubCategory ID present', () => pm.expect(json.data.id).to.be.a('string'));",
              "pm.collectionVariables.set('subCategoryId', json.data.id);",
              "console.log('subCategoryId:', json.data.id);"
            ]
          }
        }
      ],
      "request": {
        "method": "POST",
        "header": [{ "key": "Authorization", "value": "Bearer {{token}}" }],
        "url": {
          "raw": "{{baseUrl}}/catalog-service/add-subcategory/{{categoryId}}?subcategoryName=Smartphones",
          "host": ["{{baseUrl}}"], "path": ["catalog-service","add-subcategory","{{categoryId}}"],
          "query": [{ "key": "subcategoryName", "value": "Smartphones" }]
        }
      }
    },
    {
      "name": "06 — Add Product (Galaxy S24)",
      "event": [
        {
          "listen": "test",
          "script": {
            "exec": [
              "pm.test('Add Product: status 201', () => pm.response.to.have.status(201));",
              "var json = pm.response.json();",
              "pm.test('Product ID present', () => pm.expect(json.data.id).to.be.a('string'));",
              "pm.collectionVariables.set('productId', json.data.id);",
              "console.log('productId:', json.data.id);"
            ]
          }
        }
      ],
      "request": {
        "method": "POST",
        "header": [
          { "key": "Content-Type", "value": "application/json" },
          { "key": "Authorization", "value": "Bearer {{token}}" }
        ],
        "url": {
          "raw": "{{baseUrl}}/catalog-service/product/addProduct?brandId={{brandId}}&categoryId={{categoryId}}&subCategoryId={{subCategoryId}}",
          "host": ["{{baseUrl}}"], "path": ["catalog-service","product","addProduct"],
          "query": [
            { "key": "brandId",       "value": "{{brandId}}" },
            { "key": "categoryId",    "value": "{{categoryId}}" },
            { "key": "subCategoryId", "value": "{{subCategoryId}}" }
          ]
        },
        "body": {
          "mode": "raw",
          "raw": "{\n  \"name\": \"Samsung Galaxy S24\",\n  \"model\": \"SM-S921B\",\n  \"description\": \"Latest Samsung flagship with AI features\",\n  \"status\": 1\n}"
        }
      }
    },
    {
      "name": "07 — Add Variant (256GB Black)",
      "event": [
        {
          "listen": "test",
          "script": {
            "exec": [
              "pm.test('Add Variant: status 201', () => pm.response.to.have.status(201));",
