        "body": {
          "mode": "raw",
          "raw": "{\n  \"productId\": \"{{productId}}\",\n  \"variantId\": \"{{variantId}}\",\n  \"quantity\": 50\n}"
        }
      }
    },
    {
      "name": "09 — Create Coupon (SAVE10)",
      "event": [
