        "body": {
          "mode": "raw",
          "raw": "{\n  \"color\": \"Phantom Black\",\n  \"storage\": \"256GB\",\n  \"ram\": \"8GB\",\n  \"price\": 79999.00,\n  \"sku\": \"SGS24-BLK-256\"\n}"
        }
      }
    },
    {
      "name": "08 — Seed Inventory (50 units)",
      "event": [
        {
          "listen": "test",
          "script": {
            "exec": [
              "pm.test('Seed Inventory: status 200', () => pm.response.to.have.status(200));",
