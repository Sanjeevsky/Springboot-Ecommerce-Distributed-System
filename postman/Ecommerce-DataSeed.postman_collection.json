  "event": [
    {
      "listen": "prerequest",
      "script": {
        "type": "text/javascript",
        "exec": [
          "function setRunnerVar(key, value) {",
          "  pm.collectionVariables.set(key, value);",
          "  try { pm.environment.set(key, value); } catch (e) {}",
          "}",
          "",
          "function seedRunnerVariables() {",
          "  var runId = Date.now().toString();",
          "  var suffix = runId.slice(-8);",
          "  setRunnerVar('runId', runId);",
          "  setRunnerVar('runnerEmail', 'buyer_' + suffix + '@example.com');",
          "  setRunnerVar('runnerPassword', 'password123');",
          "  setRunnerVar('brandName', 'Samsung_' + suffix);",
          "  setRunnerVar('categoryName', 'Electronics_' + suffix);",
          "  setRunnerVar('subCategoryName', 'Smartphones_' + suffix);",
          "  setRunnerVar('productName', 'Galaxy S24 ' + suffix);",
          "  setRunnerVar('couponCode', 'SAVE' + suffix);",
          "  setRunnerVar('orderIdempotencyKey', 'order-' + runId);",
          "  setRunnerVar('couponOrderIdempotencyKey', 'coupon-order-' + runId);",
          "  setRunnerVar('paymentIdempotencyKey', 'payment-' + runId);",
          "}",
          "",
          "function missingRunnerVariables() {",
          "  return ['runId', 'runnerEmail', 'couponCode', 'orderIdempotencyKey', 'couponOrderIdempotencyKey', 'paymentIdempotencyKey'].some(function (key) {",
          "    return !pm.collectionVariables.get(key);",
          "  });",
          "}",
          "",
          "var requestName = pm.info.requestName || \"\";",
          "if (requestName === 'Register' || requestName.indexOf('Register User') !== -1 || missingRunnerVariables()) {",
          "  seedRunnerVariables();",
          "}"
        ]
      }
    },
    {
      "listen": "test",
      "script": {
        "type": "text/javascript",
        "exec": [
          "function responseJson() {",
          "  try {",
          "    return pm.response.json();",
          "  } catch (e) {",
          "    return {};",
          "  }",
          "}",
          "",
          "function responseData(json) {",
          "  return json && Object.prototype.hasOwnProperty.call(json, 'data') ? json.data : json;",
          "}",
          "",
          "function saveRunnerVar(key, value) {",
          "  if (value === undefined || value === null || value === '') {",
          "    return;",
          "  }",
          "  pm.collectionVariables.set(key, value);",
          "  try { pm.environment.set(key, value); } catch (e) {}",
          "  console.log('saved ' + key + ':', value);",
          "}",
          "",
          "var json = responseJson();",
          "var data = responseData(json);",
          "var rawUrl = pm.request.url ? pm.request.url.toString() : \"\";",
          "var method = pm.request.method || \"\";",
          "",
          "if (rawUrl.indexOf('/auth-service/login') !== -1) {",
          "  var token = typeof data === 'string' ? data : data && (data.token || data.accessToken || data.jwt);",
          "  saveRunnerVar('token', token);",
          "}",
          "",
          "if (data && typeof data === \"object\") {",
          "  if (rawUrl.indexOf('/catalog-service/add-brand') !== -1) { saveRunnerVar('brandId', data.id); }",
          "  if (rawUrl.indexOf('/catalog-service/addCategory') !== -1) { saveRunnerVar('categoryId', data.id); }",
          "  if (rawUrl.indexOf('/catalog-service/add-subcategory') !== -1) { saveRunnerVar('subCategoryId', data.id); }",
          "  if (rawUrl.indexOf('/catalog-service/product/addProduct') !== -1) { saveRunnerVar('productId', data.id); }",
          "  if (rawUrl.indexOf('/catalog-service/variant/add') !== -1) { saveRunnerVar('variantId', data.id); }",
          "  if (method === 'POST' && rawUrl.indexOf('/customer-service/address') !== -1) { saveRunnerVar('addressId', data.id); }",
          "  if (method === 'POST' && rawUrl.indexOf('/order-service/order') !== -1) {",
          "    saveRunnerVar('orderId', data.id);",
          "    saveRunnerVar('paymentId', data.paymentId);",
          "  }",
          "  if (rawUrl.indexOf('/order-service/order') !== -1) { saveRunnerVar('orderStatus', data.status); }",
          "  if (rawUrl.indexOf('/payment-service/') !== -1) {",
          "    saveRunnerVar('paymentId', data.id || data.paymentId);",
          "    saveRunnerVar('paymentStatus', data.status);",
          "  }",
          "  if (method === 'POST' && rawUrl.indexOf('/coupon-service/coupon') !== -1) {",
          "    saveRunnerVar('couponId', data.id);",
          "    saveRunnerVar('couponCode', data.code || pm.collectionVariables.get('couponCode'));",
          "  }",
          "  if (method === 'POST' && rawUrl.indexOf('/review-service/review') !== -1) { saveRunnerVar('reviewId', data.id); }",
          "}",
          "",
          "if (rawUrl.indexOf('/notification-service/notifications') !== -1) {",
          "  var notifications = Array.isArray(data) ? data : (data && Array.isArray(data.content) ? data.content : []);",
          "  saveRunnerVar('notificationId', notifications[0] && notifications[0].id);",
          "}"
        ]
      }
    }
  ]
}
