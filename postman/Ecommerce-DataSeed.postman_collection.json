          { "key": "Content-Type", "value": "application/json" },
          { "key": "Authorization", "value": "Bearer {{token}}" }
        ],
        "url": {
          "raw": "{{baseUrl}}/catalog-service/variant/add/{{productId}}",
          "host": ["{{baseUrl}}"], "path": ["catalog-service","variant","add","{{productId}}"]
