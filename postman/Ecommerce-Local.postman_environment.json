{
  "id": "ecommerce-local-env",
  "name": "Ecommerce Local",
  "_postman_variable_scope": "environment",
  "schema": "https://schema.getpostman.com/json/collection/v2.1.0/environment.json",
  "values": [
    {
      "key": "baseUrl",
      "value": "http://localhost:8081",
      "type": "default",
      "enabled": true,
      "description": "API Gateway URL — change to https://your-host for non-local environments"
    },
    {
      "key": "token",
      "value": "",
      "type": "secret",
      "enabled": true,
      "description": "JWT Bearer token — auto-populated by the Login request test script"
    },
    {
      "key": "runId",
      "value": "",
      "type": "default",
      "enabled": true,
      "description": "Timestamp-based run ID — auto-populated by collection pre-request scripts"
    },
    {
      "key": "runnerEmail",
      "value": "e2e.test@example.com",
      "type": "default",
      "enabled": true,
      "description": "Test user email — overridden each run by Register pre-request script with a timestamp-based unique value"
    },
    {
      "key": "runnerPassword",
      "value": "password123",
      "type": "default",
      "enabled": true,
      "description": "Test user password (min 6 chars)"
    },
    {
      "key": "brandId",
      "value": "",
      "type": "default",
      "enabled": true,
      "description": "Auto-populated by Add Brand test script"
    },
    {
      "key": "brandName",
      "value": "Samsung",
      "type": "default",
      "enabled": true,
      "description": "Brand name sent as query param in Add Brand request"
    },
    {
      "key": "categoryId",
      "value": "",
      "type": "default",
      "enabled": true,
      "description": "Auto-populated by Add Category test script"
    },
    {
      "key": "categoryName",
      "value": "Electronics",
      "type": "default",
      "enabled": true,
      "description": "Category name sent as query param in Add Category request"
    },
    {
      "key": "subCategoryId",
      "value": "",
      "type": "default",
      "enabled": true,
      "description": "Auto-populated by Add SubCategory test script"
    },
    {
      "key": "subCategoryName",
      "value": "Smartphones",
      "type": "default",
      "enabled": true,
      "description": "SubCategory name sent as query param in Add SubCategory request"
    },
    {
      "key": "productId",
      "value": "",
      "type": "default",
      "enabled": true,
      "description": "Auto-populated by Add Product test script"
    },
    {
      "key": "productName",
      "value": "Galaxy S24 Ultra",
      "type": "default",
      "enabled": true,
      "description": "Product name used in the Add Product request body"
    },
    {
      "key": "variantId",
      "value": "",
      "type": "default",
      "enabled": true,
      "description": "Auto-populated by Add Variant test script"
    },
    {
      "key": "addressId",
      "value": "",
      "type": "default",
      "enabled": true,
      "description": "Auto-populated by Add Address test script"
    },
    {
      "key": "orderId",
      "value": "",
      "type": "default",
      "enabled": true,
      "description": "Auto-populated by Create Order test script"
    },
    {
      "key": "orderStatus",
      "value": "",
      "type": "default",
      "enabled": true,
      "description": "Auto-populated by order lifecycle test scripts"
    },
    {
      "key": "paymentId",
      "value": "",
      "type": "default",
      "enabled": true,
      "description": "Auto-populated by Initiate Payment (or Create Order) test script"
    },
    {
      "key": "paymentStatus",
      "value": "",
      "type": "default",
      "enabled": true,
      "description": "Auto-populated by payment lifecycle test scripts"
    },
    {
      "key": "directPaymentOrderId",
      "value": "",
      "type": "default",
      "enabled": true,
      "description": "Auto-populated by direct payment pre-request scripts"
    },
    {
      "key": "failedPaymentOrderId",
      "value": "",
      "type": "default",
      "enabled": true,
      "description": "Auto-populated by failure-path payment pre-request scripts"
    },
    {
      "key": "orderIdempotencyKey",
      "value": "",
      "type": "default",
      "enabled": true,
      "description": "Auto-populated by collection pre-request scripts for plain order creation"
    },
    {
      "key": "couponOrderIdempotencyKey",
      "value": "",
      "type": "default",
      "enabled": true,
      "description": "Auto-populated by collection pre-request scripts for coupon order creation"
    },
    {
      "key": "paymentIdempotencyKey",
      "value": "",
      "type": "default",
      "enabled": true,
      "description": "Auto-populated by collection pre-request scripts for direct payment initiation"
    },
    {
      "key": "failedPaymentIdempotencyKey",
      "value": "",
      "type": "default",
      "enabled": true,
      "description": "Auto-populated by collection pre-request scripts for failure-path payment initiation"
    },
    {
      "key": "couponCode",
      "value": "SAVE10",
      "type": "default",
      "enabled": true,
      "description": "Coupon code — overridden each run by Register pre-request script with a unique timestamp-based code"
    },
    {
      "key": "couponId",
      "value": "",
      "type": "default",
      "enabled": true,
      "description": "Auto-populated by Create Coupon test script"
    },
    {
      "key": "reviewId",
      "value": "",
      "type": "default",
      "enabled": true,
      "description": "Auto-populated by Submit Review test script"
    },
    {
      "key": "notificationId",
      "value": "",
      "type": "default",
      "enabled": true,
      "description": "Auto-populated by Get All Notifications test script (takes first item)"
    }
  ]
}
