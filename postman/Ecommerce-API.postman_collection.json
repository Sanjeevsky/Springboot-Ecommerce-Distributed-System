          "request": {
            "method": "PUT",
            "header": [{ "key": "Authorization", "value": "Bearer {{token}}" }],
            "url": { "raw": "{{baseUrl}}/payment-service/fail/{{paymentId}}", "host": ["{{baseUrl}}"], "path": ["payment-service","fail","{{paymentId}}"] }
          }
        },
        {
          "name": "Refund Payment",
          "request": {
            "method": "PUT",
            "header": [{ "key": "Authorization", "value": "Bearer {{token}}" }],
            "url": { "raw": "{{baseUrl}}/payment-service/refund/{{paymentId}}", "host": ["{{baseUrl}}"], "path": ["payment-service","refund","{{paymentId}}"] }
          }
        }
      ]
    },
    {
      "name": "Inventory Service",
      "item": [
        {
          "name": "Add / Restock",
          "request": {
            "method": "POST",
            "header": [
              { "key": "Content-Type", "value": "application/json" },
              { "key": "Authorization", "value": "Bearer {{token}}" }
            ],
            "url": { "raw": "{{baseUrl}}/inventory-service/stock", "host": ["{{baseUrl}}"], "path": ["inventory-service","stock"] },
