          "request": {
            "method": "GET",
            "header": [{ "key": "Authorization", "value": "Bearer {{token}}" }],
            "url": {
              "raw": "{{baseUrl}}/coupon-service/coupon/validate?code=SAVE10&amount=1000",
              "host": ["{{baseUrl}}"], "path": ["coupon-service","coupon","validate"],
