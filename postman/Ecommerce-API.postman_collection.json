            "url": { "raw": "{{baseUrl}}/customer-service/address/{{addressId}}", "host": ["{{baseUrl}}"], "path": ["customer-service","address","{{addressId}}"] }
          }
        }
      ]
    },
    {
      "name": "Customer — Order",
      "item": [
        {
          "name": "Place Order",
          "event": [
            {
              "listen": "test",
              "script": {
                "exec": [
                  "var json = pm.response.json();",
                  "if (json.data && json.data.id) {",
                  "  pm.collectionVariables.set('orderId', json.data.id);",
                  "  pm.collectionVariables.set('paymentId', json.data.paymentId);",
                  "}"
                ]
              }
            }
          ],
          "request": {
            "method": "POST",
            "header": [
              { "key": "Content-Type", "value": "application/json" },
              { "key": "Authorization", "value": "Bearer {{token}}" }
            ],
            "url": { "raw": "{{baseUrl}}/customer-service/order", "host": ["{{baseUrl}}"], "path": ["customer-service","order"] },
            "body": {
              "mode": "raw",
              "raw": "{\n  \"addressId\": \"{{addressId}}\"\n}"
            }
          }
        },
        {
          "name": "Get Order",
          "request": {
            "method": "GET",
            "header": [{ "key": "Authorization", "value": "Bearer {{token}}" }],
            "url": { "raw": "{{baseUrl}}/customer-service/order/{{orderId}}", "host": ["{{baseUrl}}"], "path": ["customer-service","order","{{orderId}}"] }
          }
        },
        {
          "name": "Get My Orders",
          "request": {
            "method": "GET",
            "header": [{ "key": "Authorization", "value": "Bearer {{token}}" }],
            "url": { "raw": "{{baseUrl}}/customer-service/orders", "host": ["{{baseUrl}}"], "path": ["customer-service","orders"] }
          }
        },
        {
          "name": "Confirm Order",
          "request": {
            "method": "PUT",
            "header": [{ "key": "Authorization", "value": "Bearer {{token}}" }],
            "url": { "raw": "{{baseUrl}}/customer-service/order/{{orderId}}/confirm", "host": ["{{baseUrl}}"], "path": ["customer-service","order","{{orderId}}","confirm"] }
          }
        },
        {
          "name": "Cancel Order",
          "request": {
            "method": "PUT",
            "header": [{ "key": "Authorization", "value": "Bearer {{token}}" }],
            "url": { "raw": "{{baseUrl}}/customer-service/order/{{orderId}}/cancel", "host": ["{{baseUrl}}"], "path": ["customer-service","order","{{orderId}}","cancel"] }
          }
        }
      ]
    },
