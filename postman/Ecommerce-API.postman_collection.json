            "header": [{ "key": "Authorization", "value": "Bearer {{token}}" }],
            "url": { "raw": "{{baseUrl}}/payment-service/{{paymentId}}", "host": ["{{baseUrl}}"], "path": ["payment-service","{{paymentId}}"] }
