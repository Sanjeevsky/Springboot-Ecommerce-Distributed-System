          "request": {
            "method": "GET",
            "header": [{ "key": "Authorization", "value": "Bearer {{token}}" }],
            "url": { "raw": "{{baseUrl}}/payment-service/status/{{orderId}}", "host": ["{{baseUrl}}"], "path": ["payment-service","status","{{orderId}}"] }
          }
        },
        {
          "name": "Confirm Payment (direct)",
          "request": {
            "method": "PUT",
            "header": [{ "key": "Authorization", "value": "Bearer {{token}}" }],
            "url": { "raw": "{{baseUrl}}/payment-service/confirm/{{paymentId}}", "host": ["{{baseUrl}}"], "path": ["payment-service","confirm","{{paymentId}}"] }
          }
        },
