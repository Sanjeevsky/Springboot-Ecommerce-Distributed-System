{
  "info": {
    "name": "Ecommerce Distributed System — API",
    "_postman_id": "ecommerce-api-collection",
    "description": "Full API reference for all 10 microservices. Set baseUrl to http://localhost:8081 (API Gateway). Token is auto-set by the Login request.",
    "schema": "https://schema.getpostman.com/json/collection/v2.1.0/collection.json"
  },
  "variable": [
    { "key": "baseUrl",    "value": "http://localhost:8081" },
    { "key": "token",      "value": "" },
    { "key": "brandId",    "value": "" },
    { "key": "categoryId", "value": "" },
    { "key": "subCategoryId", "value": "" },
    { "key": "productId",  "value": "" },
    { "key": "variantId",  "value": "" },
    { "key": "addressId",  "value": "" },
    { "key": "orderId",    "value": "" },
    { "key": "paymentId",  "value": "" }
  ],
  "item": [
    {
      "name": "Auth Service",
      "item": [
        {
          "name": "Register",
          "request": {
            "method": "POST",
            "header": [{ "key": "Content-Type", "value": "application/json" }],
            "url": { "raw": "{{baseUrl}}/auth-service/signup", "host": ["{{baseUrl}}"], "path": ["auth-service","signup"] },
            "body": {
              "mode": "raw",
              "raw": "{\n  \"name\": \"Test User\",\n  \"email\": \"buyer@example.com\",\n  \"password\": \"password123\",\n  \"role\": \"USER\"\n}"
            }
          }
        },
        {
          "name": "Login",
          "event": [
            {
              "listen": "test",
              "script": {
                "exec": [
                  "var json = pm.response.json();",
                  "if (json.data) { pm.collectionVariables.set('token', json.data); }"
                ]
              }
            }
          ],
          "request": {
            "method": "POST",
            "header": [{ "key": "Content-Type", "value": "application/json" }],
            "url": { "raw": "{{baseUrl}}/auth-service/login", "host": ["{{baseUrl}}"], "path": ["auth-service","login"] },
            "body": {
              "mode": "raw",
              "raw": "{\n  \"email\": \"buyer@example.com\",\n  \"password\": \"password123\"\n}"
            }
          }
        },
        {
          "name": "Update Password",
          "request": {
            "method": "PUT",
            "header": [
              { "key": "Content-Type", "value": "application/json" },
              { "key": "Authorization", "value": "Bearer {{token}}" }
            ],
            "url": { "raw": "{{baseUrl}}/auth-service/updatePassword", "host": ["{{baseUrl}}"], "path": ["auth-service","updatePassword"] },
            "body": {
              "mode": "raw",
              "raw": "{\n  \"email\": \"buyer@example.com\",\n  \"oldPassword\": \"password123\",\n  \"newPassword\": \"newpass456\"\n}"
            }
          }
        }
      ]
    },
    {
      "name": "Catalog — Brand",
      "item": [
        {
          "name": "Add Brand",
          "event": [
            {
              "listen": "test",
              "script": {
                "exec": [
                  "var json = pm.response.json();",
                  "if (json.data && json.data.id) { pm.collectionVariables.set('brandId', json.data.id); }"
                ]
              }
            }
          ],
          "request": {
            "method": "POST",
            "header": [{ "key": "Authorization", "value": "Bearer {{token}}" }],
            "url": {
              "raw": "{{baseUrl}}/catalog-service/add-brand?name=Samsung",
              "host": ["{{baseUrl}}"], "path": ["catalog-service","add-brand"],
              "query": [{ "key": "name", "value": "Samsung" }]
            }
          }
        },
        {
          "name": "Get All Brands",
          "request": {
            "method": "GET",
            "header": [{ "key": "Authorization", "value": "Bearer {{token}}" }],
            "url": { "raw": "{{baseUrl}}/catalog-service/getBrands", "host": ["{{baseUrl}}"], "path": ["catalog-service","getBrands"] }
          }
        },
        {
          "name": "Get Brand by ID",
          "request": {
            "method": "GET",
            "header": [{ "key": "Authorization", "value": "Bearer {{token}}" }],
            "url": { "raw": "{{baseUrl}}/catalog-service/getBrand/{{brandId}}", "host": ["{{baseUrl}}"], "path": ["catalog-service","getBrand","{{brandId}}"] }
          }
        }
      ]
    },
    {
      "name": "Catalog — Category",
      "item": [
        {
          "name": "Add Category",
          "event": [
            {
              "listen": "test",
              "script": {
                "exec": [
                  "var json = pm.response.json();",
                  "if (json.data && json.data.id) { pm.collectionVariables.set('categoryId', json.data.id); }"
                ]
              }
            }
          ],
          "request": {
            "method": "POST",
            "header": [{ "key": "Authorization", "value": "Bearer {{token}}" }],
            "url": {
              "raw": "{{baseUrl}}/catalog-service/addCategory?categoryName=Electronics",
              "host": ["{{baseUrl}}"], "path": ["catalog-service","addCategory"],
              "query": [{ "key": "categoryName", "value": "Electronics" }]
            }
          }
        },
        {
          "name": "Add SubCategory",
          "event": [
            {
              "listen": "test",
              "script": {
                "exec": [
                  "var json = pm.response.json();",
                  "if (json.data && json.data.id) { pm.collectionVariables.set('subCategoryId', json.data.id); }"
                ]
              }
            }
          ],
          "request": {
            "method": "POST",
            "header": [{ "key": "Authorization", "value": "Bearer {{token}}" }],
            "url": {
              "raw": "{{baseUrl}}/catalog-service/add-subcategory/{{categoryId}}?subcategoryName=Smartphones",
              "host": ["{{baseUrl}}"], "path": ["catalog-service","add-subcategory","{{categoryId}}"],
              "query": [{ "key": "subcategoryName", "value": "Smartphones" }]
            }
          }
        },
        {
          "name": "Get All Categories",
          "request": {
            "method": "GET",
            "header": [{ "key": "Authorization", "value": "Bearer {{token}}" }],
            "url": { "raw": "{{baseUrl}}/catalog-service/getCategories", "host": ["{{baseUrl}}"], "path": ["catalog-service","getCategories"] }
          }
        }
      ]
    },
    {
      "name": "Catalog — Product",
      "item": [
        {
          "name": "Add Product",
          "event": [
            {
              "listen": "test",
              "script": {
                "exec": [
                  "var json = pm.response.json();",
                  "if (json.data && json.data.id) { pm.collectionVariables.set('productId', json.data.id); }"
                ]
              }
            }
          ],
          "request": {
            "method": "POST",
            "header": [
              { "key": "Content-Type", "value": "application/json" },
              { "key": "Authorization", "value": "Bearer {{token}}" }
            ],
            "url": {
              "raw": "{{baseUrl}}/catalog-service/product/addProduct?brandId={{brandId}}&categoryId={{categoryId}}&subCategoryId={{subCategoryId}}",
              "host": ["{{baseUrl}}"], "path": ["catalog-service","product","addProduct"],
              "query": [
                { "key": "brandId", "value": "{{brandId}}" },
                { "key": "categoryId", "value": "{{categoryId}}" },
                { "key": "subCategoryId", "value": "{{subCategoryId}}" }
              ]
            },
            "body": {
              "mode": "raw",
              "raw": "{\n  \"name\": \"Samsung Galaxy S24\",\n  \"model\": \"SM-S921B\",\n  \"description\": \"Latest Samsung flagship smartphone\",\n  \"status\": 1\n}"
            }
          }
        },
        {
          "name": "Add Variant",
          "event": [
            {
              "listen": "test",
              "script": {
                "exec": [
                  "var json = pm.response.json();",
                  "if (json.data && json.data.id) { pm.collectionVariables.set('variantId', json.data.id); }"
                ]
              }
            }
          ],
          "request": {
            "method": "POST",
            "header": [
              { "key": "Content-Type", "value": "application/json" },
              { "key": "Authorization", "value": "Bearer {{token}}" }
            ],
            "url": {
              "raw": "{{baseUrl}}/catalog-service/variant/add/{{productId}}",
              "host": ["{{baseUrl}}"], "path": ["catalog-service","variant","add","{{productId}}"]
            },
            "body": {
              "mode": "raw",
              "raw": "{\n  \"color\": \"Phantom Black\",\n  \"storage\": \"256GB\",\n  \"ram\": \"8GB\",\n  \"price\": 79999.00,\n  \"sku\": \"SGS24-BLK-256\"\n}"
            }
          }
        },
        {
          "name": "Get Product",
          "request": {
            "method": "GET",
            "url": {
              "raw": "{{baseUrl}}/catalog-service/product/getProduct/{{productId}}",
              "host": ["{{baseUrl}}"], "path": ["catalog-service","product","getProduct","{{productId}}"]
            }
          }
        },
        {
          "name": "List Products",
          "request": {
            "method": "GET",
            "url": {
              "raw": "{{baseUrl}}/catalog-service/product/list?page=0&size=20&sort=name",
              "host": ["{{baseUrl}}"], "path": ["catalog-service","product","list"],
              "query": [
                { "key": "page", "value": "0" },
                { "key": "size", "value": "20" },
                { "key": "sort", "value": "name" }
              ]
            }
          }
        },
        {
          "name": "Search Products",
          "request": {
            "method": "GET",
            "url": {
              "raw": "{{baseUrl}}/catalog-service/product/search?q=samsung&page=0&size=20",
              "host": ["{{baseUrl}}"], "path": ["catalog-service","product","search"],
              "query": [
                { "key": "q", "value": "samsung" },
                { "key": "categoryId", "value": "", "disabled": true },
                { "key": "brandId", "value": "", "disabled": true },
                { "key": "page", "value": "0" },
                { "key": "size", "value": "20" }
              ]
            }
          }
        },
        {
          "name": "Get Variant",
          "request": {
            "method": "GET",
            "header": [{ "key": "Authorization", "value": "Bearer {{token}}" }],
            "url": {
              "raw": "{{baseUrl}}/catalog-service/variant/{{variantId}}",
              "host": ["{{baseUrl}}"], "path": ["catalog-service","variant","{{variantId}}"]
            }
          }
        }
      ]
    },
    {
      "name": "Cart Service",
      "item": [
        {
          "name": "Get Cart",
          "request": {
            "method": "GET",
            "header": [{ "key": "Authorization", "value": "Bearer {{token}}" }],
            "url": { "raw": "{{baseUrl}}/cart-service/cart", "host": ["{{baseUrl}}"], "path": ["cart-service","cart"] }
          }
        },
        {
          "name": "Add Item to Cart",
          "request": {
            "method": "POST",
            "header": [
              { "key": "Content-Type", "value": "application/json" },
              { "key": "Authorization", "value": "Bearer {{token}}" }
            ],
            "url": { "raw": "{{baseUrl}}/cart-service/cart/add", "host": ["{{baseUrl}}"], "path": ["cart-service","cart","add"] },
            "body": {
              "mode": "raw",
              "raw": "{\n  \"productId\": \"{{productId}}\",\n  \"variantId\": \"{{variantId}}\",\n  \"qty\": 1\n}"
            }
          }
        },
        {
          "name": "Update Item Quantity",
          "request": {
            "method": "PUT",
            "header": [{ "key": "Authorization", "value": "Bearer {{token}}" }],
            "url": {
              "raw": "{{baseUrl}}/cart-service/cart/item/{{productId}}?qty=2",
              "host": ["{{baseUrl}}"], "path": ["cart-service","cart","item","{{productId}}"],
              "query": [{ "key": "qty", "value": "2" }]
            }
          }
        },
        {
          "name": "Remove Item from Cart",
          "request": {
            "method": "DELETE",
            "header": [{ "key": "Authorization", "value": "Bearer {{token}}" }],
            "url": {
              "raw": "{{baseUrl}}/cart-service/cart/item/{{productId}}",
              "host": ["{{baseUrl}}"], "path": ["cart-service","cart","item","{{productId}}"]
            }
          }
        },
        {
          "name": "Checkout Snapshot",
          "request": {
            "method": "GET",
            "header": [{ "key": "Authorization", "value": "Bearer {{token}}" }],
            "url": { "raw": "{{baseUrl}}/cart-service/cart/checkout", "host": ["{{baseUrl}}"], "path": ["cart-service","cart","checkout"] }
          }
        },
        {
          "name": "Clear Cart",
          "request": {
            "method": "DELETE",
            "header": [{ "key": "Authorization", "value": "Bearer {{token}}" }],
            "url": { "raw": "{{baseUrl}}/cart-service/cart/clear", "host": ["{{baseUrl}}"], "path": ["cart-service","cart","clear"] }
          }
        }
      ]
    },
    {
