                { "key": "code", "value": "SAVE10" },
                { "key": "amount", "value": "1000" }
              ]
            }
          }
        },
        {
          "name": "Apply Coupon",
          "request": {
            "method": "POST",
            "header": [{ "key": "Authorization", "value": "Bearer {{token}}" }],
            "url": {
              "raw": "{{baseUrl}}/coupon-service/coupon/apply?code=SAVE10",
              "host": ["{{baseUrl}}"], "path": ["coupon-service","coupon","apply"],
              "query": [{ "key": "code", "value": "SAVE10" }]
            }
          }
        }
      ]
    },
    {
      "name": "Review Service",
      "item": [
        {
          "name": "Submit Review",
          "request": {
            "method": "POST",
            "header": [
              { "key": "Content-Type", "value": "application/json" },
              { "key": "Authorization", "value": "Bearer {{token}}" }
            ],
            "url": { "raw": "{{baseUrl}}/review-service/review", "host": ["{{baseUrl}}"], "path": ["review-service","review"] },
            "body": {
              "mode": "raw",
              "raw": "{\n  \"productId\": \"{{productId}}\",\n  \"rating\": 5,\n  \"comment\": \"Excellent phone! Great camera and battery life.\"\n}"
            }
          }
        },
        {
          "name": "Get Approved Reviews for Product",
          "request": {
            "method": "GET",
